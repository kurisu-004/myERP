DATABASE_URL="postgresql+asyncpg://user:password@127.0.0.1:5432/dbname"
TEST_DATABASE_URL="postgresql+asyncpg://user:password@127.0.0.1:5432/test_dbname"
SNOWFLAKE_INSTANCE=0
SNOWFLAKE_SEQ=0
SNOWFLAKE_EPOCH=1735689600000

# JWT 配置
# 注意: 生产环境必须将 JWT_SECRET 替换为强随机字符串 (>= 32 字节)
# 可用: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET="dev-secret-change-me"
JWT_ALGORITHM="HS256"
JWT_EXPIRE_MINUTES=480

# 超管白名单 (用户名匹配,生产建议改用 is_superadmin 字段)
SUPERADMIN_USERNAME="superadmin"
